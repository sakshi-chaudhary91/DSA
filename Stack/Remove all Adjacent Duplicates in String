/*
Question: Remove all Adjacent Duplicates in String 
Platform: LeetCode
Topic: Stack
*/


class Solution {
    public String removeDuplicates(String s) {
        StringBuilder sb = new StringBuilder();
        
        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            int size = sb.length();
            
            if (size > 0 && sb.charAt(size - 1) == ch) {
                sb.deleteCharAt(size - 1);
            } else {
                sb.append(ch);
            }
        }
        
        return sb.toString();
    }
}
